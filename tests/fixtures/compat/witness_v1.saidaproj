{
  "schema": 1,
  "version": 1,
  "name": "Witness Game",
  "engineVersion": "0.1.0",
  "mainScene": "scenes/hub.scene",
  "runtime": {
    "maxFps": 144,
    "vsync": true
  },
  "audio": {
    "aliases": {
      "pickup": "assets/audio/pickup.ogg",
      "save": "assets/audio/save.ogg"
    }
  },
  "autoloads": {
    "GameState": "scripts/game_state.mjs"
  }
}
