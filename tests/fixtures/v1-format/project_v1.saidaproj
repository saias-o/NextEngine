{
  "schema": 1,
  "version": 1,
  "name": "V1FormatCorpus",
  "engineVersion": "1.0.0",
  "mainScene": "scenes/main.scene",
  "runtime": {
    "maxFps": 60,
    "vsync": true
  },
  "rendering": {
    "shadowResolution": 2048,
    "shadowDistance": 60.0,
    "shadowSoftness": 1.5,
    "autoMeshLods": true,
    "showColliders": false
  },
  "audio": {
    "masterVolume": 0.8,
    "default": {
      "volume": 1.0,
      "loop": false,
      "spatialized": true,
      "minDistance": 1.0,
      "maxDistance": 40.0
    },
    "aliases": {
      "click": "assets/audio/click.ogg"
    }
  },
  "autoloads": {
    "GameState": "scripts/game_state.mjs"
  }
}
